{
  "alwaysThinkingEnabled": true,
  "permissions": {
    "deny": [
      "Bash(gh pr merge *)",
      "Bash(gh pr ready *)",
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- .)",
      "Bash(git clean -f *)",
      "Bash(git rebase)",
      "Bash(git rebase *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/no-closes-in-commits.sh",
            "statusMessage": "Checking commit message conventions"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no-push-to-main.sh",
            "statusMessage": "Checking push target"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no-closes-in-pr-body.sh",
            "statusMessage": "Checking PR body conventions"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/require-signed-commits.sh",
            "statusMessage": "Checking commit signing"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no-coauthor-private.sh",
            "statusMessage": "Checking co-author policy"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/kubectl-context-required.sh",
            "statusMessage": "Checking kubectl context"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/helm-version-required.sh",
            "statusMessage": "Checking helm version pinning"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no-rebase.sh",
            "statusMessage": "Checking for git rebase"
          }
        ]
      }
    ]
  }
}
